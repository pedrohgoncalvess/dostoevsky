# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_EXPORT_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=postgres

# API
API_EXPORT_PORT=8080
SECRET_KEY=change-me

# Super Admin
SUPER_ADMIN_USERNAME=admin@dostoevsky.com
SUPER_ADMIN_PASSWORD=admin

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
