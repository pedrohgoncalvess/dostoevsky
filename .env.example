# Local audio providers (default)
LOCAL_MODELS_DIR=models
LOCAL_STT_MODEL_SIZE=base
LOCAL_STT_DEVICE=auto
LOCAL_STT_COMPUTE_TYPE=default
LOCAL_KOKORO_MODEL_PATH=
LOCAL_KOKORO_VOICES_PATH=
